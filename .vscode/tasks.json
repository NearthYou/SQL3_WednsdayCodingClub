{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build SQLprocessor",
            "command": "make",
            "args": [
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Run SQLprocessor",
            "type": "shell",
            "command": "make",
            "args": [
                "run",
                "SQL=${input:sqlFile}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Build SQLprocessor"
            ],
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Run B+ Tree Demo",
            "type": "shell",
            "command": "make",
            "args": [
                "demo-bptree"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Build SQLprocessor"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run Jungle Demo",
            "type": "shell",
            "command": "make",
            "args": [
                "demo-jungle"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Build SQLprocessor"
            ],
            "problemMatcher": []
        },
        {
            "label": "Clean SQLprocessor",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "sqlFile",
            "type": "promptString",
            "description": "실행할 SQL 파일 이름 또는 경로",
            "default": "examples/sql/demo_bptree.sql"
        }
    ]
}
